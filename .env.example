# --- XAMPP (typical local MySQL) ---
# Default is root with NO password — leave DB_PASSWORD empty.
# If you use a different user, set DB_USER to match phpMyAdmin.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# Create this database in phpMyAdmin (or mysql CLI) before migrate:
DB_NAME=twitter

NITTER_LOCAL=http://127.0.0.1:3002

# Min 32 characters; change for production
SESSION_SECRET=change-me-to-a-long-random-string-32chars-min!!

NEXT_PUBLIC_BASE_URL=http://localhost:3000
